# The Odds API key — get one free at https://the-odds-api.com/ (500 req/mo)
ODDS_API_KEY=your_key_here

# Flights domain adapter — adapters/flights/
# Run: python -m scripts.paper_trade --domain flights
# Default route: EZE (Buenos Aires Ezeiza) -> MAD (Madrid), 5 dates per run.

# SerpAPI — register free at https://serpapi.com/ (100 searches/month)
# Powers Google Flights data: best_flights + price_insights (price_level).
SERPAPI_KEY=your_serpapi_key_here

# Database connection. Leave commented → local SQLite (zero setup, paper-trade only).
#
# For Supabase, use the SESSION MODE POOLER URL (not the direct connection).
# The direct connection (db.*.supabase.co) is IPv6-only and unreachable on many
# home networks. The pooler has IPv4 and also supports create_all() migrations.
#
# Where to find it:
#   Supabase Dashboard → Project Settings → Database → Connection Pooling
#   Copy the "Session mode" string (port 5432, NOT the Transaction mode at 6543).
#
# Format (note: username becomes postgres.[project-ref]):
#   DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# If your URL starts with postgresql:// (no driver suffix), that also works —
# core/db.py auto-corrects it to postgresql+psycopg:// for psycopg3.
#
# DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# MLB season year for the stats provider (defaults to current year)
# SEASON=2026

# Phase 0 personal tracking (scripts/track.py)
# Run `python -m scripts.track pnl` once without this set — it will print
# the UUID to paste here.
# SENTINEL_USER_ID=your_user_uuid_here
# SENTINEL_USER_EMAIL=phase0@sentinel.local

# LLM provider for pick justifications (any OpenAI-compatible chat API).
# Optional — omit to run without justifications (graceful degradation, never
# called in --mock mode).
# LLM_JUSTIFIER_API_KEY=your_api_key_here
# Default: Groq (free tier, no credit card — https://groq.com). For Claude:
# https://api.anthropic.com/v1 — for OpenAI: https://api.openai.com/v1
# LLM_JUSTIFIER_BASE_URL=https://api.groq.com/openai/v1
# Default: Groq Llama. For Claude: claude-sonnet-4-20250514 — for OpenAI: gpt-4o-mini
# LLM_JUSTIFIER_MODEL=llama-3.3-70b-versatile

# Telegram notifications (optional — omit to run without notifications)
# Create a bot via @BotFather, then send a message to the bot and get your
# chat ID from: https://api.telegram.org/bot<token>/getUpdates
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
