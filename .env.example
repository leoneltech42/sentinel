# The Odds API key — get one free at https://the-odds-api.com/ (500 req/mo)
ODDS_API_KEY=your_key_here

# Database connection. Leave commented → local SQLite (zero setup, paper-trade only).
#
# For Supabase, use the SESSION MODE POOLER URL (not the direct connection).
# The direct connection (db.*.supabase.co) is IPv6-only and unreachable on many
# home networks. The pooler has IPv4 and also supports create_all() migrations.
#
# Where to find it:
#   Supabase Dashboard → Project Settings → Database → Connection Pooling
#   Copy the "Session mode" string (port 5432, NOT the Transaction mode at 6543).
#
# Format (note: username becomes postgres.[project-ref]):
#   DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# If your URL starts with postgresql:// (no driver suffix), that also works —
# core/db.py auto-corrects it to postgresql+psycopg:// for psycopg3.
#
# DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# MLB season year for the stats provider (defaults to current year)
# SEASON=2026

# Telegram notifications (optional — omit to run without notifications)
# Create a bot via @BotFather, then send a message to the bot and get your
# chat ID from: https://api.telegram.org/bot<token>/getUpdates
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
